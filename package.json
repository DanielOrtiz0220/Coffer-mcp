{
  "name": "coffer-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "node scripts/db-migrate.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "1.14.1",
    "hono": "4.7.8",
    "pg": "8.15.6",
    "pino": "9.6.0",
    "zod": "3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "9.26.0",
    "@types/node": "22.15.3",
    "@types/pg": "8.11.11",
    "eslint": "9.26.0",
    "husky": "9.1.7",
    "node-pg-migrate": "7.9.1",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "typescript-eslint": "8.32.0",
    "vitest": "3.1.3"
  },
  "packageManager": "pnpm@11.1.1"
}
